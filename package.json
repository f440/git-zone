{
  "name": "@f440/git-zone",
  "version": "0.2.0",
  "description": "CLI for managing git worktrees by branch, ref, and commit",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/f440/git-zone#readme",
  "bugs": {
    "url": "https://github.com/f440/git-zone/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f440/git-zone.git"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "git-zone": "bin/git-zone"
  },
  "files": [
    "bin",
    "completions",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/cli.ts --target=node --outfile=./dist/cli.js",
    "check:completion": "zsh -n completions/_git-zone",
    "prepack": "bun run build",
    "release:draft": "gh release create \"v${npm_package_version}\" --repo f440/git-zone --draft --generate-notes",
    "test": "bun test",
    "check": "bun test && bun run build && bun run check:completion"
  },
  "publishConfig": {
    "access": "public"
  }
}
